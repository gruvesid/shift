# ─────────────────────────────────────────────────────────────────
# SF2Dynamics — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────
APP_ENV=development                         # development | production
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── PostgreSQL Database ───────────────────────────────────────────
# Local dev (docker-compose.dev.yml spins up postgres on port 5432):
DATABASE_URL=postgresql://sf2user:sf2password@localhost:5433/sf2dynamics
# Azure Flexible Server:
# DATABASE_URL=postgresql://sf2user:your-password@sf2dynamics-db.postgres.database.azure.com:5432/sf2dynamics?sslmode=require
POSTGRES_PASSWORD=sf2password    # used by docker-compose for the PG container

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=                             # leave blank for dev, set for prod

# ── Qdrant Vector DB ──────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=sf2d_field_mappings       # collection name for vector search

# ── Salesforce ────────────────────────────────────────────────────
# These are saved per-connection in DB; these are fallback/test values
SF_AUTH_METHOD=oauth                        # oauth | password
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_INSTANCE_URL=https://your-org.my.salesforce.com
SF_DOMAIN=test                              # test (sandbox) | login (production)
SF_IS_SANDBOX=true
SF_API_VERSION=59.0

# ── Dynamics 365 ──────────────────────────────────────────────────
D365_TENANT_ID=
D365_CLIENT_ID=
D365_CLIENT_SECRET=
D365_ENVIRONMENT_URL=https://your-org.crm.dynamics.com

# ── LLM Provider ─────────────────────────────────────────────────
LLM_PROVIDER=openai                         # openai | anthropic | cohere
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
COHERE_API_KEY=
COHERE_MODEL=command-r-08-2024

# ── Microsoft Fabric (optional — existing Fabric integration) ─────
FABRIC_SQL_TENANT_ID=
FABRIC_SQL_SERVICE_PRINCIPAL_ID=
FABRIC_SQL_SERVICE_PRINCIPAL_SECRET=
FABRIC_SQL_SERVER=
FABRIC_SQL_DATABASE=

# ── Azure (for prod deployment + Azure Function deploy) ───────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
ACR_LOGIN_SERVER=                           # e.g. myregistry.azurecr.io
IMAGE_TAG=latest

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
